    .SUM(n11_1),
    .COUT(n11_2),
    .I0(i_reset_cnt[1]),
    .I1(GND),
    .I3(GND),
    .CIN(n12_5) 
);
defparam n11_s.ALU_MODE=0;
  ALU n10_s (
    .SUM(n10_1),
    .COUT(n10_2),
    .I0(i_reset_cnt[2]),
