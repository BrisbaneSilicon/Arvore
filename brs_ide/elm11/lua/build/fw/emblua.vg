    .CLK(i_sysclk),
    .RESET(n15_5) 
);
defparam i_reset_cnt_0_s0.INIT=1'b0;
  DFF i_resetn_p3_s0 (
    .Q(i_resetn_p3),
    .D(i_resetn_p4),
    .CLK(i_sysclk) 
);
defparam i_resetn_p3_s0.INIT=1'b0;
  DFF i_resetn_p2_s0 (
    .Q(i_resetn_p2),
    .D(i_resetn_p3),
    .CLK(i_sysclk) 
);
defparam i_resetn_p2_s0.INIT=1'b0;
  DFF i_resetn_p1_s0 (
    .Q(i_resetn_p1),
    .D(i_resetn_p2),
    .CLK(i_sysclk) 
);
defparam i_resetn_p1_s0.INIT=1'b0;
  DFF i_resetn_s0 (
    .Q(O_psram_reset_n_d[1]),
    .D(i_resetn_p1),
    .CLK(i_sysclk) 
);
defparam i_resetn_s0.INIT=1'b0;
  DFFR i_reset_cnt_3_s0 (
    .Q(i_reset_cnt[3]),
    .D(n9_1),
    .CLK(i_sysclk),
    .RESET(n15_5) 
);
defparam i_reset_cnt_3_s0.INIT=1'b0;
